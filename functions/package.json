{
  "name": "functions",
  "private": true,
  "main": "lib/index.js",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "npm --prefix .. run build -w folclore-game-engine && node esbuild.mjs",
