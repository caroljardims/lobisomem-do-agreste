  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "esbuild": "^0.24.0",
    "folclore-game-engine": "file:../packages/game-engine",
    "typescript": "^5.6.3"
  }
}
