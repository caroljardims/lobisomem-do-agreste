rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    // Per-user profile (client may create/update mirror fields from Auth).
    function userForbiddenPatch() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([
        'gamesPlayed',
        'gamesWon',
        'totalPoints',
        'mvpCount',
        'podiumCount',
        'bestGame',
        'favoriteRole',
        'rolePlayCounts',
        'isPremium',
        'premiumSince',
        'stripeCustomerId',
        'createdAt',
        'uid'
      ]);
    }

    match /users/{userId} {
      allow read: if isAuthed() && request.auth.uid == userId;
      allow create: if isAuthed()
        && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow update: if isAuthed()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && !userForbiddenPatch();
      allow delete: if false;
    }

    match /gameHistory/{gameId} {
      allow read: if isAuthed() && (
        request.auth.uid in resource.data.participantUids
        || !('participantUids' in resource.data)
      );
      allow write: if false;
    }

    match /publicLeaderboard/{userId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // All writes go through Cloud Functions (Admin SDK, bypasses rules).
    // Clients are read-only. Any authenticated user can read any room they
    // know the code for — codes are short-lived and unguessable in practice.
    match /rooms/{roomCode} {
      allow read: if isAuthed();
      allow write: if false;

      match /playerPrivate/{playerId} {
        allow read: if isAuthed() && request.auth.uid == resource.data.authUid;
        allow write: if false;
      }

      match /{document=**} {
        allow read: if isAuthed();
        allow write: if false;
      }
    }
  }
}
